//
// Device Settings for Emulators
//

let
    EMULATOR: {
      LoRa: {
          max_fCnt_Jump: 50
      },
      DriftGroups: {
          temperature: {
              maxDrift: 2.0,
              minValues: 3,
              timeSpan: 10000,
              driftPrecision: 2,
              metric: temperature 
          },
          light: {
              maxDrift: 40,
              minValues: 2,    
              timeSpan: 10000,
              driftPrecision: 3,
              metric: light 
          }
      },
      Rate: {
          period: 4000,
          min: 1,
          max: 2
      }
    },
    
    EMULATOR_1: $EMULATOR << {
      DriftGroups: {
          temperature: {
              maxDrift: 2.0,
              minValues: 3,
              timeSpan: 10000,
              driftPrecision: 2,
