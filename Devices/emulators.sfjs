          },
          light: {
              maxDrift: 40,
              minValues: 2,    
              timeSpan: 10000,
              driftPrecision: 3,
              metric: light 
          }
      },
    },

    EMULATOR_2: $EMULATOR << {
        Rate: {
          period: 4000,
          min: 2,
          max: 4
        }
      }

in
